# FIRE Environment Variables
# Copy this file to .env and populate all variables prior to execution.

# Controls the host IP address for the FastMCP server.
# Expected format: IPv4 address (e.g., 0.0.0.0 or 127.0.0.1)
MCP_SERVER_HOST=0.0.0.0

# Controls the port number for the FastMCP server listener.
# Expected format: Integer between 1024 and 65535 (e.g., 8000)
MCP_SERVER_PORT=8000

# Defines the connection string for the local SQLite database.
# Expected format: sqlite:/// relative or absolute path (e.g., sqlite:///data/mock_ehr.sqlite)
DATABASE_URL=sqlite:///data/mock_ehr.sqlite
