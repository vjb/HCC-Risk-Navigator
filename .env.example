# ─────────────────────────────────────────────────────────────────────────────
# Auto-Auth Pre-Cog Engine — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key — used by pa_engine.py for the GPT-4o-mini PA reasoning calls.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: LangChain tracing (leave blank to disable)
LANGCHAIN_API_KEY=

# MCP Server settings
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///data/mock_ehr.sqlite
